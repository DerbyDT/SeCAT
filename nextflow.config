// ============================================================================
// nextflow.config — SeCAT v4.1
//
// System-agnostic configuration. Container is pulled automatically from GHCR.
// No manual container setup required.
//
// Basic usage:
//   nextflow run main.nf -profile slurm,singularity -params-file params.yaml
//   nextflow run main.nf -profile local              -params-file params.yaml
//
// HPC site-specific overrides (partition names, account flags etc.):
//   nextflow run main.nf -profile slurm,singularity \
//       -c conf/custom.config -params-file params.yaml
//
// JASMIN LOTUS2:
//   nextflow run DerbyDT/SeCAT -profile slurm,singularity \
//       -c conf/jasmin.config -params-file params.yaml
//
// Resume after failure:
//   Add -resume to any of the above commands.
// ============================================================================

params {
    // ── Required inputs ──────────────────────────────────────────────────────
    // These two parameters MUST be provided; the pipeline will fail without them.

    // Path to secat_manifest.tsv — the tab-separated file listing all studies,
    // their FASTA paths, metadata paths, primer names, and trim offsets.
    manifest        = null

    // Path to the SILVA aligned FASTA reference (e.g., SILVA_138.1_SSURef_NR99).
    // Must be pre-aligned; alignment columns define the common coordinate system.
    reference_db    = null

    // ── Analysis mode ────────────────────────────────────────────────────────
    // Controls how amplicon coordinates are determined for each study.
    // Valid values: 'study' (recommended — empirical DECIPHER alignment of ASVs
    // to SILVA) or 'primer' (legacy — parses coordinates from primer name strings).
    // Changing to 'primer' skips all alignment and trusts metadata naming conventions.
    analysis_mode   = 'study'

    // Root output directory. All results, reports, and intermediate files are
    // written under this path. Default 'output' creates ./output/ relative to launch dir.
    outdir          = 'output'

    // ── Simulation parameters ────────────────────────────────────────────────
    // These control the null-model simulation engine (04_simulate.R) that
    // generates expected Bray-Curtis dissimilarity distributions under the
    // null hypothesis of no trimming effect. Defaults are calibrated via
    // systematic testing for optimal Type I error control at alpha = 0.05.

    // Number of independent simulation replicates per study-pair.
    // Range: 50–1000. Higher = tighter null distributions but slower runtime.
    // 100 provides stable p-values; increase to 500+ for publication figures.
    num_simulations         = 100

    // Maximum SILVA sequences used to build the simulated community pool.
    // Range: 1000–50000. Larger pools increase taxonomic diversity of simulations
    // but consume more memory. 10000 balances realism and performance.
    sim_max_silva_subset    = 10000

    // If true, loads a pre-built SILVA subset from cache rather than resampling.
    // Set false to regenerate (e.g., after changing sim_max_silva_subset).
    sim_use_prebuilt_subset = true

    // Statistical model for simulated species abundances.
    // Valid values: 'lognormal' (realistic; mimics natural SAD), 'uniform'.
    // Lognormal produces the hollow-curve rank-abundance pattern typical of
    // real microbial communities.
    sim_abundance_model     = 'lognormal'

    // Mean of the log-normal abundance distribution (log-scale).
    // Higher values shift the distribution toward more abundant taxa.
    // Range: 1–10. Default 5 produces realistic community structure.
    sim_lognormal_mu        = 5

    // Standard deviation of the log-normal distribution (log-scale).
    // Controls evenness: lower sigma = more even communities.
    // Range: 0.5–4. Default 2 produces moderate dominance structure.
    sim_lognormal_sigma     = 2

    // Whether to simulate PCR amplification bias based on GC content.
    // When true, sequences with GC content near sim_pcr_optimal_gc are
    // preferentially amplified, mimicking real PCR bias.
    sim_add_pcr_bias        = true

    // Number of PCR cycles to simulate. More cycles amplify GC bias.
    // Typical range: 20–35. Must match experimental protocol for realism.
    sim_pcr_cycles          = 25

    // Strength of GC-content bias during simulated PCR (0–1).
    // Higher values cause stronger preferential amplification of GC-optimal sequences.
    sim_pcr_gc_bias         = 0.65

    // Optimal GC content for PCR efficiency (0–1).
    // Sequences closest to this value are amplified most efficiently.
    sim_pcr_optimal_gc      = 0.50

    // Whether to add simulated sequencing errors (substitutions + indels).
    // When true, introduces realistic noise that tests robustness of trimming verdicts.
    sim_add_errors          = true

    // Per-base substitution error rate. Illumina MiSeq typical: 0.001–0.005.
    // Default 0.003 reflects quality-filtered amplicon data.
    sim_error_rate          = 0.003

    // Per-base insertion/deletion rate. Much rarer than substitutions on Illumina.
    // Default 0.00003 is conservative.
    sim_indel_rate          = 0.00003

    // If true, error rate increases toward the 3' end of reads, mimicking
    // Illumina's characteristic quality decay pattern.
    sim_error_position_bias = true

    // Whether to add simulated chimeric sequences to the community.
    // Chimeras can inflate diversity; disabled by default as most pipelines
    // (DADA2, Deblur) remove chimeras before ASV tables reach SeCAT.
    sim_add_chimeras        = false

    // Fraction of sequences that are chimeric (0–1). Only applies if
    // sim_add_chimeras = true. Range: 0.01–0.10 typical.
    sim_chimera_rate        = 0.02

    // ── Trimming parameters ──────────────────────────────────────────────────
    // Control how the trimming search space is defined. These determine the
    // resolution and extent of the trim-step grid evaluated in 06_analyse_real.R.

    // Trimming step mode. Valid values: 'absolute' (fixed bp increments) or
    // 'relative' (percentage of amplicon length). 'absolute' is recommended
    // for interpretability and reproducibility across studies.
    trim_step_mode          = 'absolute'

    // Base-pair increment per trim step. Each step removes this many bp from
    // one or both ends. Range: 10–500. Smaller = finer resolution but slower.
    // Default 100 bp provides a good balance of resolution and speed.
    trim_increment          = 100

    // Default maximum number of trim steps to evaluate per study if no
    // consensus-based limit applies. Range: 10–200.
    default_max_trim_steps  = 50

    // Extra trim steps evaluated beyond the consensus amplicon boundary.
    // Acts as a safety buffer to ensure the optimal trim is not missed
    // if the consensus coordinates are slightly off. Range: 5–50.
    consensus_buffer_steps  = 20

    // Hard upper limit on total trim (in bp) regardless of other settings.
    // Prevents runaway trimming on unusually long amplicons. Range: 500–5000.
    max_absolute_trim_steps = 2000

    // ── Quality filters ──────────────────────────────────────────────────────
    // Filters applied to ASV/OTU tables before Bray-Curtis computation.
    // These remove rare/noisy features that could distort dissimilarity.

    // Minimum relative abundance threshold for retaining a taxon (0–1).
    // 0 = no filtering. Set to e.g. 0.001 to remove singletons/ultra-rare taxa.
    // Increasing this reduces noise but risks removing real low-abundance taxa.
    min_relative_abundance  = 0

    // Minimum number of taxa required in a sample after filtering to compute
    // Bray-Curtis. Samples with fewer taxa are excluded. Range: 1–10.
    // Default 3 prevents degenerate distance calculations from near-empty samples.
    min_taxa_for_bray       = 3

    // Minimum median read depth across samples for a study to be included.
    // Studies below this threshold are flagged as low-quality. Range: 50–5000.
    min_median_read_depth   = 100

    // ── Changepoint detection ────────────────────────────────────────────────
    // Controls the PELT changepoint algorithm used to detect significant shifts
    // in the Bray-Curtis dissimilarity curve as a function of trim level.

    // Penalty method for changepoint detection. Valid values: 'MANUAL', 'BIC',
    // 'AIC', 'MBIC'. 'MANUAL' allows direct control via the multiplier below.
    // Defaults calibrated for optimal Type I error control.
    changepoint_penalty_method     = 'MANUAL'

    // Multiplier for the changepoint penalty (only used when method = 'MANUAL').
    // Higher values = fewer detected changepoints (more conservative).
    // Range: 0.1–10. Default 1 is calibrated for 100 simulations.
    changepoint_penalty_multiplier = 1

    // ── Null model thresholds ────────────────────────────────────────────────
    // These parameters define how the simulation-based null model determines
    // whether observed trimming effects are statistically significant.

    // P-value threshold for the null model test. Observed dissimilarity changes
    // exceeding the (1 - p_threshold) quantile of simulated null distributions
    // are deemed significant. Standard: 0.05 for alpha = 5%.
    null_model_p_threshold      = 0.05

    // Minimum number of consecutive significant trim steps required to declare
    // a trimming effect. Prevents isolated false positives from triggering
    // a verdict. Range: 1–10. Default 3 reduces Type I errors substantially.
    null_model_min_consecutive  = 3

    // Minimum trim amount (in bp) before significance testing begins.
    // Ignores trivially small trims. Range: 0–50. Default 5 bp.
    null_model_min_trim_bp      = 5

    // Absolute Bray-Curtis dissimilarity threshold for the distance-cutoff
    // verdict. Trim effects below this magnitude are considered biologically
    // negligible regardless of p-value. Range: 0.01–0.50.
    // Default 0.15 calibrated to distinguish meaningful ecological shifts.
    distance_cutoff_threshold   = 0.15

    // Minimum trim (bp) before the distance-cutoff verdict applies.
    // Same logic as null_model_min_trim_bp but for the cutoff-based test.
    distance_cutoff_min_trim_bp = 5

    // ── Consensus parameters ─────────────────────────────────────────────────
    // Control how individual study verdicts are aggregated into a consensus
    // trimming recommendation across all studies in the meta-analysis.

    // Maximum acceptable Bray-Curtis increase at the consensus trim level.
    // If any study exceeds this threshold, the consensus is flagged. Range: 0.05–0.50.
    // Default 0.20 allows moderate dissimilarity increase before rejection.
    consensus_optimization_threshold = 0.20

    // Minimum number of studies that must agree for a consensus verdict.
    // Range: 2–N. Default 3 ensures robustness against single-study outliers.
    min_consensus_studies            = 3

    // Minimum fraction of studies covered by the consensus amplicon window.
    // Range: 0.0–1.0. Default 0.50 = at least half the studies must overlap
    // the consensus region. Lower values allow sparser coverage.
    min_consensus_coverage           = 0.50

    // ── Reference alignment ──────────────────────────────────────────────────
    // Control how the SILVA reference is handled during ASV-to-reference alignment.

    // Whether to use the full SILVA database or a random subset for profile
    // alignment. Valid values: 'full' or 'subset'. 'subset' is much faster
    // and sufficient for coordinate determination. 'full' may be needed for
    // unusual/novel amplicon regions.
    reference_alignment_mode = 'subset'

    // Number of SILVA sequences in the subset (only used when mode = 'subset').
    // Range: 1000–50000. Default 5000 provides reliable profiles. Increase
    // if alignment quality is poor for unusual primer pairs.
    reference_subset_size    = 5000

    // ── Merge parameters ─────────────────────────────────────────────────────
    // Control how individual study ASV/OTU tables are merged after trimming.

    // Merge algorithm. Valid values: 'advanced' (handles taxonomy harmonisation,
    // duplicate resolution, and count normalisation) or 'simple' (direct
    // concatenation). 'advanced' is recommended for cross-study comparisons.
    merge_method       = 'advanced'

    // Whether to harmonise metadata columns across studies during merge.
    // When true, standardises column names, factor levels, and missing values.
    harmonize_metadata = true

    // ── Report parameters ────────────────────────────────────────────────────
    // Control output figure quality and caching behaviour.

    // DPI for rasterised plots (PNG). Range: 72–600. Higher = larger files
    // but sharper figures. 300 is publication-quality.
    plot_dpi         = 300

    // If true, regenerate all outputs even if cached results exist.
    // Useful after parameter changes. Default false uses cached results.
    force_regenerate = false

    // ── ASV sampling for mapping ─────────────────────────────────────────────
    // Whether to use all ASVs or a subsample when aligning to SILVA.
    // true = use every ASV (slower but exhaustive); false = subsample.
    use_all_asvs = true

    // Number of ASVs to subsample per study (only used when use_all_asvs = false).
    // Range: 100–5000. Default 500 is sufficient for accurate coordinate mapping.
    asv_sample_size        = 500

    // ── Study mapping ────────────────────────────────────────────────────────
    // Controls how per-ASV alignment coordinates are collapsed to study-level.

    // Consensus method for determining study amplicon boundaries.
    // Valid values: 'modal' (most frequent start/end — recommended),
    // 'percentile' (10th/90th percentiles), 'minimum' (full extent).
    // 'modal' is robust to outlier/chimeric ASVs.
    study_alignment_method = 'modal'

    // Maximum allowed mismatches when matching primer sequences to reference.
    // Range: 0–10. Higher values allow degenerate primers but risk false matches.
    max_primer_mismatch    = 4

    // ── Pipeline stage controls ──────────────────────────────────────────────
    // Toggle optional pipeline stages on/off.

    // If true, applies trimming automatically after the verdict step without
    // waiting for manual review. Set false (default) for interactive workflows
    // where the user inspects verdicts before committing to trim.
    auto_trim      = false

    // If true, runs multi-tier ecological validation (alpha/beta diversity,
    // taxonomic composition checks) after the merge step. Adds runtime but
    // provides quality assurance that trimming did not distort biology.
    run_validation = true

    // Comma-separated taxonomic levels for validation. Each level gets its own
    // set of diversity comparisons. Valid tokens: ASV, Genus, Family, Order, etc.
    validation_levels    = 'ASV,Genus,Family'
}

// ── Process resource labels ──────────────────────────────────────────────────
// Each Nextflow process in main.nf declares a label (e.g., label 'mem_16g')
// that maps to a resource tier below. This decouples resource requests from
// process logic: to change memory for all "medium" processes, edit one line here.
//
// The errorStrategy 'finish' allows already-running sibling tasks to complete
// before the pipeline exits on error, avoiding wasted compute on HPC.
//
// The label naming convention is: mem_{amount}[_cpu{n}].
// Processes without a multi-CPU label default to 1 CPU.
// Time limits are set conservatively; HPC schedulers will kill jobs exceeding them.
process {
    errorStrategy = 'finish'

    withLabel: 'mem_4g'        { memory = '4 GB';  cpus = 1;  time = '2h'  }  // Light tasks: manifest parsing, config loading
    withLabel: 'mem_8g'        { memory = '8 GB';  cpus = 1;  time = '4h'  }  // Per-study ASV loading, coordinate extraction
    withLabel: 'mem_16g'       { memory = '16 GB'; cpus = 1;  time = '4h'  }  // DECIPHER alignment (small studies)
    withLabel: 'mem_16g_cpu4'  { memory = '16 GB'; cpus = 4;  time = '4h'  }  // Parallel Bray-Curtis computation
    withLabel: 'mem_18g'       { memory = '18 GB'; cpus = 1;  time = '8h'  }  // SILVA subset loading + profile alignment
    withLabel: 'mem_30g'       { memory = '30 GB'; cpus = 1;  time = '12h' }  // Full SILVA reference operations
    withLabel: 'mem_48g_cpu16' { memory = '48 GB'; cpus = 16; time = '12h' }  // Large-scale merge with parallelisation
    withLabel: 'mem_64g'       { memory = '64 GB'; cpus = 1;  time = '24h' }  // Full reference alignment (all ASVs mode)
    withLabel: 'mem_64g_cpu4'  { memory = '64 GB'; cpus = 4;  time = '48h' }  // Validation with multiple taxonomic levels

    // Cap concurrent simulation processes to avoid overwhelming the scheduler.
    // Each simulation is independent (embarrassingly parallel) but collectively
    // they can saturate I/O if all 100+ launch simultaneously.
    withName: 'RUN_SIMULATION' { maxForks = 50 }
}

// ── Execution profiles ──────────────────────────────────────────────────────
// Profiles are selected at runtime with -profile (comma-separated).
// Typically you combine an executor profile (slurm, sge, local) with a
// container profile (singularity, docker).
// Example: -profile slurm,singularity
profiles {

    // ── slurm ────────────────────────────────────────────────────────────────
    // Use on HPC clusters running the SLURM workload manager (e.g., JASMIN,
    // university clusters). Each Nextflow process is submitted as a separate
    // SLURM job with resources defined by the label system above.
    // For site-specific settings (partition names, account flags, scratch
    // directories), supply an additional config: -c conf/custom.config
    slurm {
        process.executor = 'slurm'
    }

    // ── sge ──────────────────────────────────────────────────────────────────
    // Use on HPC clusters running Sun/Oracle Grid Engine (SGE/UGE).
    // Each label maps to SGE-specific clusterOptions that request virtual
    // memory (h_vmem), file-size limits (h_fsize), and parallel environments
    // (pe smp N). -cwd runs in the current working directory; -V exports
    // all environment variables to the job.
    sge {
        process.executor = 'sge'
        process {
            withLabel: 'mem_4g'        { clusterOptions = '-cwd -V -l h_vmem=4G' }
            withLabel: 'mem_8g'        { clusterOptions = '-cwd -V -l h_vmem=8G,h_fsize=100G' }
            withLabel: 'mem_16g'       { clusterOptions = '-cwd -V -l h_vmem=16G' }
            withLabel: 'mem_16g_cpu4'  { clusterOptions = '-cwd -V -l h_vmem=16G -pe smp 4' }
            withLabel: 'mem_18g'       { clusterOptions = '-cwd -V -l h_vmem=18G' }
            withLabel: 'mem_30g'       { clusterOptions = '-cwd -V -l h_vmem=30G' }
            withLabel: 'mem_48g_cpu16' { clusterOptions = '-cwd -V -l h_vmem=48G -pe smp 16' }
            withLabel: 'mem_64g'       { clusterOptions = '-cwd -V -l h_vmem=64G,h_fsize=100G' }
            withLabel: 'mem_64g_cpu4'  { clusterOptions = '-cwd -V -l h_vmem=64G,h_fsize=100G -pe smp 4' }
        }
    }

    // ── local ────────────────────────────────────────────────────────────────
    // Use for development, testing, or small datasets on a single machine
    // (laptop, workstation, cloud VM). All processes run on the local machine
    // with a combined cap of 8 CPUs and 32 GB RAM. Not recommended for
    // production runs with >10 studies or >100 simulations.
    local {
        process.executor = 'local'
        executor.cpus    = 8
        executor.memory  = '32 GB'
    }

    // ── singularity ──────────────────────────────────────────────────────────
    // Use on HPC systems where Docker is unavailable (most academic clusters
    // prohibit Docker for security reasons). Singularity runs containers
    // without requiring root privileges.
    // The container image is pulled automatically from GitHub Container
    // Registry (GHCR) on first use and cached locally thereafter.
    // autoMounts binds standard paths; runOptions additionally binds the
    // project directory and the manifest's parent directory so all input
    // files are visible inside the container.
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = "--bind ${projectDir} --bind ${params.manifest.replaceAll('/[^/]+$', '')}"
        process.container      = 'docker://ghcr.io/derbydt/secat:latest'
    }

    // ── docker ───────────────────────────────────────────────────────────────
    // Use on local machines, CI/CD systems, or cloud VMs where Docker is
    // available. Runs the container as the current user (not root) to ensure
    // output files have correct ownership. Preferred for local development
    // and testing; use singularity for HPC production runs.
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'ghcr.io/derbydt/secat:latest'
    }
}

// ── Pipeline manifest ────────────────────────────────────────────────────────
// Metadata block read by Nextflow and displayed in reports/logs.
// Also used by `nextflow info` and nf-core tooling for pipeline discovery.
manifest {
    name            = 'SeCAT'                    // Short pipeline identifier (used in logs and Nextflow Tower)
    author          = 'David Terrey'             // Primary author / maintainer
    homePage        = 'https://github.com/DerbyDT/SeCAT'  // Repository URL for documentation and issue tracking
    description     = 'Sequence Consensus Amplicon Trimming — cross-study 16S amplicon harmonisation'  // One-line summary shown in `nextflow info`
    version         = '4.1'                      // Semantic version; update on each release
    nextflowVersion = '>=23.04.0'                // Minimum Nextflow version required (DSL2 features)
    mainScript      = 'main.nf'                  // Entry-point script executed by `nextflow run`
}

// ── Nextflow introspection reports ───────────────────────────────────────────
// These three blocks enable automatic generation of run diagnostics.
// All are written to {outdir}/reports/ and overwrite previous runs.

// report:   HTML execution report with per-process CPU/memory/time usage,
//           task counts, and error summaries. Essential for debugging failed
//           runs and optimising resource labels.
report   { enabled = true; overwrite = true; file = "${params.outdir}/reports/nextflow_report.html" }

// timeline: Interactive Gantt-chart HTML showing when each task started,
//           ran, and finished. Useful for identifying bottlenecks and
//           verifying parallelism on HPC schedulers.
timeline { enabled = true; overwrite = true; file = "${params.outdir}/reports/nextflow_timeline.html" }

// dag:      Directed Acyclic Graph visualisation of the pipeline workflow.
//           Shows process dependencies and channel connections. Useful for
//           understanding pipeline architecture and verifying data flow.
dag      { enabled = true; overwrite = true; file = "${params.outdir}/reports/nextflow_dag.html" }
