// ============================================================================
// nextflow.config — SeCAT v4.1
//
// System-agnostic configuration. Container is pulled automatically from GHCR.
// No manual container setup required.
//
// Basic usage:
//   nextflow run DerbyDT/SeCAT -profile slurm,singularity -params-file params.yaml
//   nextflow run DerbyDT/SeCAT -profile local              -params-file params.yaml
//
// HPC site-specific overrides (partition names, account flags etc.):
//   nextflow run DerbyDT/SeCAT -profile slurm,singularity \
//       -c conf/custom.config -params-file params.yaml
//
// JASMIN LOTUS2:
//   nextflow run DerbyDT/SeCAT -profile slurm,singularity \
//       -c conf/jasmin.config -params-file params.yaml
//
// Resume after failure:
//   Add -resume to any of the above commands.
// ============================================================================

params {
    // ── Required ──────────────────────────────────────────────────────────────
    manifest        = null       // path to secat_manifest.tsv
    reference_db    = null       // path to SILVA aligned FASTA

    // ── Analysis mode ─────────────────────────────────────────────────────────
    analysis_mode   = 'study'    // 'study' or 'primer'
    outdir          = 'output'

    // ── Simulations ───────────────────────────────────────────────────────────
    num_simulations         = 100
    sim_max_silva_subset    = 10000
    sim_use_prebuilt_subset = true
    sim_abundance_model     = 'lognormal'
    sim_lognormal_mu        = 5
    sim_lognormal_sigma     = 2
    sim_add_pcr_bias        = true
    sim_pcr_cycles          = 25
    sim_pcr_gc_bias         = 0.65
    sim_pcr_optimal_gc      = 0.50
    sim_add_errors          = true
    sim_error_rate          = 0.003
    sim_indel_rate          = 0.00003
    sim_error_position_bias = true
    sim_add_chimeras        = false
    sim_chimera_rate        = 0.02

    // ── Trimming ──────────────────────────────────────────────────────────────
    trim_step_mode          = 'scaled'
    trim_increment          = 5
    default_max_trim_steps  = 50
    consensus_buffer_steps  = 20
    max_absolute_trim_steps = 2000

    // ── Quality filters ───────────────────────────────────────────────────────
    min_relative_abundance  = 0
    min_taxa_for_bray       = 3
    min_median_read_depth   = 100

    // ── Changepoint detection ─────────────────────────────────────────────────
    changepoint_penalty_method     = 'MANUAL'
    changepoint_penalty_multiplier = 1

    // ── Null model ────────────────────────────────────────────────────────────
    null_model_p_threshold      = 0.05
    null_model_min_consecutive  = 3
    null_model_min_trim_bp      = 5
    distance_cutoff_threshold   = 0.15
    distance_cutoff_min_trim_bp = 5

    // ── Consensus ─────────────────────────────────────────────────────────────
    consensus_optimization_threshold = 0.20
    min_consensus_studies            = 3
    min_consensus_coverage           = 0.50

    // ── Reference alignment ───────────────────────────────────────────────────
    reference_alignment_mode = 'subset'
    reference_subset_size    = 5000

    // ── Merge ─────────────────────────────────────────────────────────────────
    merge_method       = 'advanced'
    harmonize_metadata = true

    // ── Reports ───────────────────────────────────────────────────────────────
    plot_dpi         = 300
    force_regenerate = false

    use_all_asvs_for_mafft = true
    asv_sample_size        = 500

    // ── Study mapping ─────────────────────────────────────────────────────────
    study_alignment_method = 'modal'
    max_primer_mismatch    = 4

    // ── Pipeline stages ───────────────────────────────────────────────────────
    auto_trim      = false   // trim automatically after verdict (skips manual review step)
    run_validation = true    // run multi-tier ecological validation after merge
}

process {
    errorStrategy = 'finish'

    withLabel: 'mem_4g'        { memory = '4 GB';  cpus = 1;  time = '2h'  }
    withLabel: 'mem_8g'        { memory = '8 GB';  cpus = 1;  time = '4h'  }
    withLabel: 'mem_16g'       { memory = '16 GB'; cpus = 1;  time = '4h'  }
    withLabel: 'mem_16g_cpu4'  { memory = '16 GB'; cpus = 4;  time = '4h'  }
    withLabel: 'mem_18g'       { memory = '18 GB'; cpus = 1;  time = '8h'  }
    withLabel: 'mem_30g'       { memory = '30 GB'; cpus = 1;  time = '12h' }
    withLabel: 'mem_48g_cpu16' { memory = '48 GB'; cpus = 16; time = '12h' }
    withLabel: 'mem_64g'       { memory = '64 GB'; cpus = 1;  time = '24h' }
    withLabel: 'mem_64g_cpu4'  { memory = '64 GB'; cpus = 4;  time = '48h' }

    withName: 'RUN_SIMULATION' { maxForks = 50 }
}

profiles {

    // ── slurm ─────────────────────────────────────────────────────────────────
    // Generic SLURM profile. Use -c conf/custom.config to set partition names
    // and any site-specific clusterOptions (account flags, scratch directives).
    slurm {
        process.executor = 'slurm'
    }

    // ── sge ───────────────────────────────────────────────────────────────────
    sge {
        process.executor = 'sge'
        process {
            withLabel: 'mem_4g'        { clusterOptions = '-cwd -V -l h_vmem=4G' }
            withLabel: 'mem_8g'        { clusterOptions = '-cwd -V -l h_vmem=8G,h_fsize=100G' }
            withLabel: 'mem_16g'       { clusterOptions = '-cwd -V -l h_vmem=16G' }
            withLabel: 'mem_16g_cpu4'  { clusterOptions = '-cwd -V -l h_vmem=16G -pe smp 4' }
            withLabel: 'mem_18g'       { clusterOptions = '-cwd -V -l h_vmem=18G' }
            withLabel: 'mem_30g'       { clusterOptions = '-cwd -V -l h_vmem=30G' }
            withLabel: 'mem_48g_cpu16' { clusterOptions = '-cwd -V -l h_vmem=48G -pe smp 16' }
            withLabel: 'mem_64g'       { clusterOptions = '-cwd -V -l h_vmem=64G,h_fsize=100G' }
            withLabel: 'mem_64g_cpu4'  { clusterOptions = '-cwd -V -l h_vmem=64G,h_fsize=100G -pe smp 4' }
        }
    }

    // ── local ─────────────────────────────────────────────────────────────────
    local {
        process.executor = 'local'
        executor.cpus    = 8
        executor.memory  = '32 GB'
    }

    // ── singularity ───────────────────────────────────────────────────────────
    // Pulls the container automatically from GHCR. No manual build needed.
    // The image is cached locally after first pull.
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'docker://ghcr.io/derbydt/secat:latest'
    }

    // ── docker ────────────────────────────────────────────────────────────────
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'ghcr.io/derbydt/secat:latest'
    }
}

manifest {
    name            = 'SeCAT'
    author          = 'David Terry'
    homePage        = 'https://github.com/DerbyDT/SeCAT'
    description     = 'Sequence Consensus Amplicon Trimming — cross-study 16S amplicon harmonisation'
    version         = '4.1'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

report   { enabled = true; file = "${params.outdir}/reports/nextflow_report.html" }
timeline { enabled = true; file = "${params.outdir}/reports/nextflow_timeline.html" }
dag      { enabled = true; file = "${params.outdir}/reports/nextflow_dag.html" }
