// ============================================================================
// nextflow.config — SeCAT v4.0
//
// Defines executor profiles, resource labels, and container settings.
// Select a profile at runtime:
//   nextflow run main.nf -profile sge
//   nextflow run main.nf -profile slurm
//   nextflow run main.nf -profile lsf
//   nextflow run main.nf -profile local
//   nextflow run main.nf -profile sge,singularity
//   nextflow run main.nf -profile sge,docker
// ============================================================================

params {

    // ---- Required inputs ----
    manifest        = null      // Path to secat_manifest_clean.tsv
    reference_db    = null      // Path to SILVA_138.2_SSURef_NR99_tax_silva_full_align_trunc.fasta

    // ---- External tool paths (not needed when using container) ----
    vsearch_path    = 'vsearch' // Set to full path if vsearch is not on PATH

    // ---- Output directory ----
    outdir = 'output'

    // ---- Simulation settings ----
    num_simulations         = 100
    sim_max_silva_subset    = 10000
    sim_use_prebuilt_subset = true
    sim_abundance_model     = 'lognormal'
    sim_lognormal_mu        = 5
    sim_lognormal_sigma     = 2
    sim_add_pcr_bias        = true
    sim_pcr_cycles          = 25
    sim_pcr_gc_bias         = 0.65
    sim_pcr_optimal_gc      = 0.50
    sim_add_errors          = true
    sim_error_rate          = 0.003
    sim_indel_rate          = 0.00003
    sim_error_position_bias = true
    sim_add_chimeras        = false
    sim_chimera_rate        = 0.02

    // ---- Trim analysis ----
    trim_step_mode          = 'scaled'  // 'scaled' (recommended) or 'absolute'
    trim_increment          = 5         // bp per step (absolute mode only)
    default_max_trim_steps  = 50
    consensus_buffer_steps  = 20
    max_absolute_trim_steps = 2000

    // ---- Quality thresholds ----
    min_relative_abundance  = 0
    min_taxa_for_bray       = 3
    min_median_read_depth   = 100

    // ---- Changepoint detection ----
    changepoint_penalty_method     = 'MANUAL' // 'AIC', 'SIC', or 'MANUAL'
    changepoint_penalty_multiplier = 1

    // ---- Null model ----
    null_model_p_threshold      = 0.05
    null_model_min_consecutive  = 3
    null_model_min_trim_bp      = 5
    distance_cutoff_threshold   = 0.15
    distance_cutoff_min_trim_bp = 5

    // ---- Consensus region ----
    consensus_optimization_threshold = 0.20
    min_consensus_studies            = 3
    min_consensus_coverage           = 0.50

    // ---- Reference alignment (DECIPHER profile alignment) ----
    reference_alignment_mode = 'subset'  // 'subset' (recommended) or 'full'
    reference_subset_size    = 5000      // Reference sequences used for profile alignment
    use_all_asvs             = true      // true = align all ASVs; false = subsample to asv_sample_size
    asv_sample_size          = 500       // ASVs to subsample when use_all_asvs = false
    study_alignment_method   = 'modal'

    // ---- Merge settings ----
    merge_method        = 'advanced' // 'simple' or 'advanced'
    harmonize_metadata  = true

    // ---- Report settings ----
    plot_dpi         = 300
    force_regenerate = false

    // ---- Stage 7: auto-trim ----
    // false (default): pipeline stops after verdicts for human review.
    // true: immediately trims all KEEP-verdict studies without review.
    auto_trim = false

    // ---- Stage 8: validation ----
    // Runs VALIDATE_TRIMMING after MERGE_DATASETS.
    // Compares unaligned_cleaned/ vs aligned_trimmed/ across ASV, Genus,
    // and Family levels. Set false to skip (saves ~1 hour on large datasets).
    run_validation = true
}

// ============================================================================
// Resource labels — referenced in process modules via `label 'mem_Xg'`
// ============================================================================

process {

    errorStrategy = 'finish'

    withLabel: 'mem_4g'        { memory = '4 GB';  cpus = 1; time = '2h'  }
    withLabel: 'mem_8g'        { memory = '8 GB';  cpus = 1; time = '4h'  }
    withLabel: 'mem_16g'       { memory = '16 GB'; cpus = 1; time = '4h'  }
    withLabel: 'mem_16g_cpu4'  { memory = '16 GB'; cpus = 4; time = '4h'  }
    withLabel: 'mem_18g'       { memory = '18 GB'; cpus = 1; time = '8h'  }
    withLabel: 'mem_30g'       { memory = '30 GB'; cpus = 1; time = '12h' }
    withLabel: 'mem_64g'       { memory = '64 GB'; cpus = 1; time = '24h' }
    withLabel: 'mem_64g_cpu4'  { memory = '64 GB'; cpus = 4; time = '48h' }

    // Throttle simulation workers to prevent cluster overload (replaces SGE -tc 50)
    withName: 'RUN_SIMULATION' { maxForks = 50 }
}

// ============================================================================
// Executor profiles
// ============================================================================

profiles {

    sge {
        process.executor = 'sge'
        process {
            withLabel: 'mem_4g'        { clusterOptions = '-cwd -V -l h_vmem=4G' }
            withLabel: 'mem_8g'        { clusterOptions = '-cwd -V -l h_vmem=8G,h_fsize=100G' }
            withLabel: 'mem_16g'       { clusterOptions = '-cwd -V -l h_vmem=16G' }
            withLabel: 'mem_16g_cpu4'  { clusterOptions = '-cwd -V -l h_vmem=16G -pe smp 4' }
            withLabel: 'mem_18g'       { clusterOptions = '-cwd -V -l h_vmem=18G' }
            withLabel: 'mem_30g'       { clusterOptions = '-cwd -V -l h_vmem=30G' }
            withLabel: 'mem_64g'       { clusterOptions = '-cwd -V -l h_vmem=64G,h_fsize=100G' }
            withLabel: 'mem_64g_cpu4'  { clusterOptions = '-cwd -V -l h_vmem=64G,h_fsize=100G -pe smp 4' }
        }
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'compute'
    }

    lsf {
        process.executor = 'lsf'
    }

    local {
        process.executor = 'local'
        executor.cpus    = 8
        executor.memory  = '32 GB'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'oras://ghcr.io/YOUR_ORG/secat:4.0'
    }

    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'ghcr.io/YOUR_ORG/secat:4.0'
    }
}

// ============================================================================
// Pipeline metadata
// ============================================================================

manifest {
    name            = 'SeCAT'
    author          = 'Terry et al.'
    description     = 'Sequence Consensus Amplicon Trimming — 16S rRNA amplicon region standardisation'
    version         = '4.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}

report   { enabled = true; file = "${params.outdir}/reports/nextflow_report.html"   }
timeline { enabled = true; file = "${params.outdir}/reports/nextflow_timeline.html" }
dag      { enabled = true; file = "${params.outdir}/reports/nextflow_dag.html"      }
